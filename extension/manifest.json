{
    "manifest_version": 3,

    "name": "Memora",

    "description": "Browse Everything. Forget Nothing.",

    "version": "2.0.0",

    "action": {
        "default_popup": "popup.html"
    },

    "background": {
        "service_worker": "background.js"
    },

    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "scripting"
    ],

    "host_permissions": [
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*",
        "<all_urls>"
    ],

    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],

    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}